# Copia este archivo como .env y rellena los valores si quieres conectar tu tienda Shopify.
# Si no creas .env, la app usará datos mock en local.

# Shopify Configuration
VITE_SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=tu_token_aqui
# Opcional (por defecto 2025-10)
# VITE_SHOPIFY_STOREFRONT_API_VERSION=2025-10
