# Copia este archivo como .env y rellena los valores si quieres conectar tu tienda Shopify.
# Si no creas .env, la app usará datos mock en local.

# Shopify Configuration
VITE_SHOPIFY_STORE_DOMAIN=mrbrownmx.myshopify.com
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=ad03aab414e8a8da8c419222d265c7a5

# Newsletter / Admin API (server-side only — used by api/newsletter.ts)
