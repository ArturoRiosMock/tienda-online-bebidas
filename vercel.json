{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/tools/customr/:path*",
      "destination": "https://mr-brown-mayoreo.myshopify.com/tools/customr/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
